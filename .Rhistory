library(ggpubr)
my_data <- read.csv('./Example Data/EX 2/blanks_LOQ_20220919.csv', header = T,
encoding = 'UTC-8')
# QQ plot to visually assess normality
qq <- ggqqplot(my_data$X52)
print(qq)
# Shapiro-Wilk test (formal normality test)
shapiro.test(my_data$x52)
View(my_data)
